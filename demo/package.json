{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "sync": "mkdir -p pkg && cp -r ../rustoku-wasm/pkg/* ./pkg/",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"*.{ts,js,html,css}\" \"src/**/*.{ts,css}\" \"tests/**/*.ts\" package.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.14",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-static-copy": "^4.1.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "rustoku-wasm": "file:../rustoku-wasm/pkg",
    "vite-plugin-wasm": "^3.6.0"
  }
}
